// Secrets.example.xcconfig
//
// Copy this file to `Secrets.xcconfig` (which is gitignored) and fill in the
// values from your app in the Spotify Developer Dashboard:
// https://developer.spotify.com/dashboard
//
// DO NOT commit Secrets.xcconfig.

SPOTIFY_CLIENT_ID =
SPOTIFY_CLIENT_SECRET =

// Must match a Redirect URI registered for your Spotify app.
// Note: xcconfig treats `//` as a comment, so the scheme's slashes are escaped
// with ${} to keep the value intact, e.g. spotifyrecommendation:${}/callback
SPOTIFY_REDIRECT_URI = spotifyrecommendation:/$()/callback

